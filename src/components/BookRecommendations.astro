---
import { BookOpen, Quote } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";
import type { BookSchema } from "../schemas/book";

type BookEntry = CollectionEntry<"books">;
type BookLike = BookEntry | BookSchema | { data?: BookSchema };

type Props = {
  books?: BookLike[];
};

const { books = [] } = Astro.props as Props;

// Helpers to support content entries (`getCollection`) and plain book objects.
// Prefer `book.data.*` when available (Astro content entries expose frontmatter
// under `data`). Provide safe defaults so component doesn't break if fields
// are missing.
const field = (
  book: BookLike,
  key: keyof BookSchema,
  fallback = "",
): string => {
  if (!book) return fallback;
  if (book.data && Object.prototype.hasOwnProperty.call(book.data, key)) {
    const value = book.data[key];
    return typeof value === "string" ? value : fallback;
  }
  if (Object.prototype.hasOwnProperty.call(book, key)) {
    const value = (book as Record<string, unknown>)[key as string];
    return typeof value === "string" ? value : fallback;
  }
  return fallback;
};

const getLanguage = (book: BookLike) => field(book, "language", "");
const getTitle = (book: BookLike) => field(book, "title", "Untitled");
const getAuthor = (book: BookLike) => field(book, "author", "Unknown");
const getCategory = (book: BookLike) => field(book, "category", "Book");
const getImage = (book: BookLike) => field(book, "image", "default.png");

const getWhy = (book: BookLike) => field(book, "why", "");
---

<section id="books" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div
        class="inline-flex items-center gap-2 px-4 py-2 bg-emerald-100 rounded-full mb-4"
      >
        <BookOpen class="w-4 h-4 text-emerald-600" />
        <span class="text-sm text-emerald-700">Reading List</span>
      </div>
      <h2 class="text-4xl md:text-5xl mb-4 text-slate-900">
        Books That Changed My Code
      </h2>
      <p class="text-lg text-slate-600 max-w-2xl mx-auto">
        The books that shaped my journey as a developer—from fundamentals to
        philosophy
      </p>
    </div>

    <div
      class="mb-12 bg-linear-to-r from-emerald-50 to-green-50 rounded-2xl p-8 border-l-4 border-emerald-500"
    >
      <Quote class="w-10 h-10 text-emerald-600 mb-4" />
      <p class="text-xl text-slate-700 italic mb-2">
        "A developer who doesn't read books is like a carpenter who doesn't
        sharpen their tools."
      </p>
      <p class="text-slate-600">
        Reading isn't just learning—it's investing in your craft.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        books.map((book, index) => (
          <article
            key={index}
            class="group hover:shadow-xl transition-all duration-300 border-2 hover:border-emerald-200 overflow-hidden rounded-2xl bg-white"
          >
            <div class="relative h-48 overflow-hidden">
              <img
                src={`/images/books/${getImage(book)}`}
                alt={getTitle(book)}
                loading="lazy"
                onerror="this.onerror=null;this.src='/images/default.png';"
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
              />
            </div>

            <div class="pt-6 pb-6 px-6">
              <div class="flex items-center gap-2 mb-3">
                <span class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-xs rounded-full">
                  {getCategory(book)}
                </span>
                {getLanguage(book) && (
                  <span class="inline-block px-2 py-1 bg-slate-100 text-slate-700 text-xs rounded-full">
                    {getLanguage(book)}
                  </span>
                )}
              </div>
              <h3 class="text-xl mb-1 text-slate-900 group-hover:text-emerald-700 transition-colors">
                {getTitle(book)}
              </h3>
              <p class="text-sm text-slate-500 mb-3">by {getAuthor(book)}</p>

              <div class="bg-emerald-50 rounded-lg p-3 mb-4">
                <p class="text-xs text-emerald-900">
                  <strong>Why it matters:</strong> {getWhy(book)}
                </p>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div
      class="mt-16 bg-linear-to-br from-slate-900 to-emerald-900 rounded-3xl p-12 text-center text-white"
    >
      <BookOpen class="w-16 h-16 mx-auto mb-6 text-emerald-300" />
      <h3 class="text-3xl mb-4">Currently Reading</h3>
      <p class="text-lg text-slate-300 mb-6 max-w-2xl mx-auto">
        Always learning, always growing. I typically read 2-3 technical books
        per quarter. Have a recommendation? I'd love to hear it!
      </p>
    </div>
  </div>
</section>
